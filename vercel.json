{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/server.js"
    },
    {
      "src": "/invoice",
      "dest": "/server.js"
    },
    {
      "src": "/live",
      "dest": "/server.js"
    },
    {
      "src": "/track",
      "dest": "/server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/asset/dtcImage.png",
      "dest": "/asset/dtcImage.png"
    },
    {
      "src": "/asset/main.d65b6151.css",
      "dest": "/asset/main.d65b6151.css"
    },
    {
      "src": "/asset/main.441f1ef8.js",
      "dest": "/asset/main.441f1ef8.js"
    },
    {
      "src": "/asset/(.*)",
      "dest": "/asset/$1"
    },
    {
      "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|svg|otf|ttf|woff|woff2|csv|proto|JPG))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
