{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/invoice.html",
      "dest": "/invoice.html"
    },
    {
      "src": "/live.html",
      "dest": "/live.html"
    },
    {
      "src": "/live",
      "dest": "/live.html"
    },
    {
      "src": "/track.html",
      "dest": "/track.html"
    },
    {
      "src": "/track",
      "dest": "/track.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*\\.(html|css|js|jpg|jpeg|png|gif|svg|otf|ttf|woff|woff2|csv|proto))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
