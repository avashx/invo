# Server Configuration
PORT=3001

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/busTrackerDB?retryWrites=true&w=majority

# GTFS API Configuration
GTFS_URL=https://otd.delhi.gov.in/api/realtime/VehiclePositions.pb?key=YOUR_API_KEY_HERE

# Optional: API Key if required
GTFS_API_KEY=your_api_key_here

# Update Intervals (in milliseconds)
BUS_FETCH_INTERVAL=10000
MAX_RETRIES=3

# Feature Flags
ENABLE_MONGODB=true
ENABLE_SOCKET_IO=true
